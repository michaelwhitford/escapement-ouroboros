{:paths ["src"]
 :deps  {;; Escapement is the runtime Ouroboros runs on — DE-FORKED: released
         ;; upstream RC9 from Clojars (was a fork sha carrying an :extra-body
         ;; passthrough for chat_template_kwargs/id_slot/cache_prompt). Those
         ;; llama.cpp knobs now ride our own pure-consumer backend
         ;; ouroboros.llm.llamacpp, injected via lib/run's :backend escape hatch
         ;; and driven by MODELED escapement fields (:thinking → enable_thinking,
         ;; cache-control marker → cache_prompt, :conversation/id → id_slot), so
         ;; NO fork is needed. bb reads escapement's deps.edn transitively
         ;; (statecharts/guardrails/malli/cheshire/http-client) — lib path, no pathom.
         com.fulcrologic/escapement {:mvn/version "1.0.0-RC9"}
         ;; guardrails MUST stay EXPLICITLY pinned (any modern version) —
         ;; Pathom 2's transitive 0.0.12 breaks bb (escapement's documented
         ;; constraint). Pin it BEFORE pathom. 1.2.16 → 1.3.3 verified green.
         com.fulcrologic/guardrails {:mvn/version "1.3.3"}
         ;; Pathom 2 — the mementum EQL veneer (S1 λ interface). Same version
         ;; escapement runs for its /api, so one pathom on the bb classpath.
         com.wsscode/pathom         {:mvn/version "2.4.0"}}
 :tasks {smoke {:doc      "First light: escapement.lib/run smoke — no-LLM Phase A + local llama.cpp Phase B."
                :requires ([ouroboros.smoke :as smoke])
                :task     (smoke/-main)}
         llama-smoke {:doc      "Live probe of the de-forked llama.cpp backend (ouroboros.llm.llamacpp) @ localhost:5100: proves :thinking :disabled ⇒ empty reasoning_content, :conversation/id ⇒ id_slot pinning (/slots), and a real send-turn. SKIPs (exit 0) if the server is down."
                      :requires ([ouroboros.smoke-llama :as smoke-llama])
                      :task     (smoke-llama/-main)}
         maintain {:doc      "The maintenance sweep (rung 1) — bb maintain [slug]: sequential hermetic proposer runs over the schedule table (2×2 roster by tag); each run emits an :s1/report signal; artifacts land uncommitted (human-gated). No arg ⇒ full sweep; slug ⇒ that genome only (replaces the old bb curate ≡ bb maintain harness-knowledge)."
                   :requires ([ouroboros.schedule :as schedule])
                   :task     (apply schedule/-main *command-line-args*)}
         proposals {:doc      "The morning-coffee inbox — pending proposals/ (algedonic first) + uncommitted memory candidates awaiting human review."
                    :requires ([ouroboros.proposals :as proposals])
                    :task     (proposals/-main)}
         compact {:doc      "THE canonical Ouroboros chatbot — interactive λ-compact chat: per-message assistant compaction (memory=λ, cache-stable); fresh worker per turn via re-entry; stdin ingress, /quit to end (needs local llama.cpp @ localhost:5100). OPT-IN continuation: bb compact <prior-session-id> bootstraps a NEW session from that session's boundary-folded tail (bb sessions lists candidates)."
                  :requires ([ouroboros.compact :as compact])
                  :task     (apply compact/-main *command-line-args*)}
         sessions {:doc      "The session picker — conversation sessions newest-first: id · date · msgs(λ) · lineage (⤴ bootstrapped-from) · first human line. The CLI projection of the future web-UI resume button."
                   :requires ([ouroboros.compact :as compact])
                   :task     (compact/sessions-main)}
         judge {:doc      "The JUDGE kind (verdict topology) — bb judge \"<subject>\": forced submit_verdict {:status pass|fail :notes} per the llm-judge genome (ornith @ localhost:5102)."
                :requires ([ouroboros.verdict :as verdict])
                :task     (apply verdict/-main "llm-judge" *command-line-args*)}
         roster {:doc     "The compiled agent roster report — provenance, grants, escalations for every genome in the roster."
                 :requires ([ouroboros.agents :as agents])
                 :task     (println (apply agents/report *command-line-args*))}
         score {:doc      "The SCORER kind (verdict topology) — bb score \"<subject>\": forced submit_verdict {:score 1-10 :notes} per the gene-scorer genome (rubric-anchored)."
                :requires ([ouroboros.verdict :as verdict])
                :task     (apply verdict/-main "gene-scorer" *command-line-args*)}
         cache-report {:doc      "KV-cache reuse report for a session — bb cache-report [session-id] (default: latest). Flags mid-session BUSTs (slot evicted → full re-prefill)."
                       :requires ([ouroboros.cache-report :as cache-report])
                       :task     (apply cache-report/-main *command-line-args*)}
         experiment {:doc      "Run an experiment suite — bb experiment <slug> (experiments/<slug>.edn): sweeps model×thinking×condition×subject, assesses via the suite's measure, persists results to experiments/results/ (gitignored)."
                     :requires ([ouroboros.experiment :as experiment])
                     :task     (apply experiment/-main *command-line-args*)}
         genes {:doc      "Gene-DB intake — bb genes [genome-slug]: decompose an APPROVED genome into mementum/genes/ (3 gates: EBNF parse · Malli envelope · tree-hash dedupe), then AUTONOMOUS scoped commits (--only, gene-db author) for every gate-passing dirty gene."
                :requires ([ouroboros.gene :as gene])
                :task     (apply gene/-main *command-line-args*)}
         author {:doc      "The AUTHOR kind (shot topology, plan stage) — bb author \"<task>\": read design pages + src, produce ONE implementation-plan document (session artifact reflection.md); next-stage gate: feed the plan path to bb builder."
                 :requires ([ouroboros.workflow :as workflow])
                 :task     (apply workflow/-main "author" *command-line-args*)}
         builder {:doc      "The BUILDER kind (shot-loop, build stage) — bb builder \"<task, incl. plan path if any>\": real file edits + the dev/run-tests gate; output ≡ the UNCOMMITTED working-tree diff (prints status+diffstat); human reviews and commits."
                  :requires ([ouroboros.workflow :as workflow])
                  :task     (apply workflow/-main "builder" *command-line-args*)}
         editor {:doc      "The EDITOR kind (S4→S5 adaptive channel, v1) — bb editor \"<recommendation ∨ proposal path>\": harness-editor edits Layer-2 genome files, llm-judge GATES the diff (fail ⇒ bounded revise with notes, k=2); REQUIRES a clean tree; output ≡ the UNCOMMITTED diff + judge trail; human reviews and commits."
                 :requires ([ouroboros.workflow :as workflow])
                 :task     (apply workflow/-main "editor" *command-line-args*)}
         analyst {:doc      "The ANALYST kind (shot, INFORMS gate) — bb analyst \"<code question>\": clj-kondo-backed code-nav (lint · ns-graph · var-defs · usages · unused), map-first then targeted reads; output ≡ an evidence-cited report (session artifact); read-only, no side effects."
                  :requires ([ouroboros.workflow :as workflow])
                  :task     (apply workflow/-main "analyst" *command-line-args*)}
         test  {:doc         "Run unit tests under test/ (deterministic, no network)."
                :extra-paths ["test"]
                :requires    ([ouroboros.test-runner :as tr])
                :task        (tr/run!)}}}
