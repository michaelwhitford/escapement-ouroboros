{:paths ["src"]
 :deps  {;; Escapement is the runtime Ouroboros runs on. Local/root so bb reads
         ;; escapement's deps.edn transitively (statecharts/guardrails/malli/
         ;; cheshire/http-client) — the lib path needs no pathom.
         com.fulcrologic/escapement {:local/root "/Users/mwhitford/src/escapement"}
         ;; guardrails MUST stay pinned 1.2.16 — Pathom 2's transitive 0.0.12
         ;; breaks bb (escapement's documented constraint). Pin it BEFORE pathom.
         com.fulcrologic/guardrails {:mvn/version "1.2.16"}
         ;; Pathom 2 — the mementum EQL veneer (S1 λ interface). Same version
         ;; escapement runs for its /api, so one pathom on the bb classpath.
         com.wsscode/pathom         {:mvn/version "2.4.0"}}
 :tasks {smoke {:doc      "First light: escapement.lib/run smoke — no-LLM Phase A + local llama.cpp Phase B."
                :requires ([ouroboros.smoke :as smoke])
                :task     (smoke/-main)}
         loop  {:doc      "Loop B, first breath — chart observes mementum, PROPOSES one memory (uncommitted; human-gated)."
                :requires ([ouroboros.loop :as loop])
                :task     (loop/-main)}
         cold  {:doc      "Cold-compiler prototype — parallel :hot/:cold regions; hot conversation compressed into verified λ each turn (needs local llama.cpp @ localhost:5100)."
                :requires ([ouroboros.cold :as cold])
                :task     (cold/-main)}
         test  {:doc         "Run unit tests under test/ (deterministic, no network)."
                :extra-paths ["test"]
                :requires    ([ouroboros.test-runner :as tr])
                :task        (tr/run!)}}}
